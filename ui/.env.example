# ============================================================================
# UI (Streamlit) — variables de entorno
# En el monorepo, docker-compose inyecta estos valores (ver docker-compose.yml
# servicio `ui`). Este archivo documenta el contrato para correrla standalone.
# ============================================================================

# ---- Backend API ----
# En compose: http://api:8000. En prod (ECS, llamada interna server-side):
# http://api.ml-training.local:8000
API_URL=http://localhost:8000

# ---- Timeouts (segundos) ----
TIMEOUT_HEALTH=5
TIMEOUT_READ=10
TIMEOUT_WRITE=15
TIMEOUT_BATCH=30

# ---- Cache TTL (segundos) ----
CACHE_TTL_HEALTH=60
CACHE_TTL_VARIETIES=120
CACHE_TTL_FORECASTS=30

# ---- Logging ----
LOG_LEVEL=info

# ---- Ruteo (solo prod) ----
# Detrás del ALB en /app/*. Vacío en local. Lo setea la task de ECS.
# STREAMLIT_SERVER_BASE_URL_PATH=app
