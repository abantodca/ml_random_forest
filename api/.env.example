# ============================================================================
# API (FastAPI) — variables de entorno
# En el monorepo, docker-compose inyecta estos valores (ver docker-compose.yml
# servicio `api`). Este archivo documenta el contrato para correrla standalone.
# ============================================================================

# ---- Base de datos (REQUERIDO) ----
# Reusa la instancia Postgres/RDS de MLflow, base `forecasts` (la API la crea
# en el primer arranque si no existe — ver app/models/database.ensure_database).
DATABASE_URL=postgresql://mlflow:mlflow@localhost:5432/forecasts

# ---- MLflow (REQUERIDO) ----
# En compose: http://mlflow:5000. En prod (ECS): http://mlflow.ml-training.local:5000
MLFLOW_TRACKING_URI=http://localhost:5000
# false = carga modelos bajo demanda (arranque rápido, menos RAM). Recomendado
# en prod para acotar memoria. true = precarga todas las variedades al boot.
MLFLOW_PRELOAD_MODELS=false
# Prefijo COMPLETO del registered model. Debe coincidir con MODEL_REGISTRY_PREFIX
# del trainer (src/config.py), default 'rnd-forest-'.
EXPERIMENT_PREFIX=rnd-forest-

# ---- CORS ----
CORS_ORIGINS=http://localhost:8501

# ---- Servidor ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEBUG=false

# ---- AWS (para que MLflow/boto3 descargue artifacts desde S3) ----
# Local: se monta ~/.aws y se usan estas vars. Prod: lo provee el task role de ECS.
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default
