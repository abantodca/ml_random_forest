# ============================================================================
# .dockerignore - Archivos a excluir del build de Docker
# ============================================================================
# Optimiza el build excluyendo archivos innecesarios

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
*.md
docs/
README*
MIGRATION_GUIDE.md

# CI/CD
.github/
.gitlab-ci.yml

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Database
*.db
*.sqlite
*.sqlite3

# OS
.DS_Store
Thumbs.db

# Estructura antigua (si existe)
legacy/

# Temporal
tmp/
temp/
*.tmp

# pgAdmin data
pgadmin_data/

# Tests
tests/
test_*.py
*_test.py
